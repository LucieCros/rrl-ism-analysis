# =============================================================================
# spectral_tools — .gitignore
# =============================================================================
# Rule of thumb:
#   TRACK  : code, reference files, config, notebooks (cleared outputs)
#   IGNORE : generated data, large binary data, outputs, environment files
# =============================================================================


# =============================================================================
# Generated data — too large or fully reproducible from the pipeline
# =============================================================================

# Raw observation FITS blocs
data/raw/
data/processed/

# Cleaned per-observation temp files
*/Calph/temp/
*/Halph/temp/
*/reduced-gal/

# Parameter-space grids (NetCDF) — regenerated by generate_grid.py
grids/
finegrids_beam1/

# Stacked spectra (FITS) — regenerated by run_time_average.py
alltime_*.fits
no_nov-alltime_*.fits

# Pipeline log files
LOG_temp_*.txt


# =============================================================================
# Pipeline outputs — figures, results, cached intermediates
# =============================================================================

outputs/
results/
figures/

# grids - dust and chi²
*.nc

# Pickle cache files (except reference interpolators in files/)
*.pkl
*.pickle
!files/B1B2.pickle
!files/alphagamma.pickle


# =============================================================================
# Jupyter notebooks — strip cell outputs before committing
# (use nbstripout: pip install nbstripout && nbstripout --install)
# =============================================================================

# Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/


# =============================================================================
# Python build and packaging artefacts
# =============================================================================

__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST


# =============================================================================
# Virtual environments and package managers
# =============================================================================

.venv/
venv/
env/
ENV/
.conda/
conda-env/


# =============================================================================
# IDE and editor files
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, etc.)
.idea/
*.iml

# Spyder
.spyderproject.cfg
.spyproject/

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*


# =============================================================================
# OS-generated files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini


# =============================================================================
# Testing and coverage
# =============================================================================

.pytest_cache/
.coverage
htmlcov/
.tox/


# =============================================================================
# Documentation build
# =============================================================================

docs/_build/
docs/api/


# =============================================================================
# Secrets and local configuration overrides
# =============================================================================

# Local path overrides — create a local_config.yaml for machine-specific paths
local_config.yaml
.env
